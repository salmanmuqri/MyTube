# ── Django ───────────────────────────────────────────
# Generate with: openssl rand -base64 50
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-base64-50
# Set to 0 in production, 1 during local development only
DEBUG=0

# Comma-separated list of allowed hostnames
# Docker / local: localhost,127.0.0.1
# Railway: add your Railway backend domain, e.g. myapp.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ────────────────────────────
# Docker Compose: these match the postgres service credentials above
# Railway: copy the values from your Railway PostgreSQL service's "Connect" tab
POSTGRES_DB=mytube
POSTGRES_USER=mytube
POSTGRES_PASSWORD=strong_password_here
# POSTGRES_HOST and POSTGRES_PORT are set by docker-compose (backend service)
# Railway: copy the "Host" and "Port" values from your Railway PostgreSQL service
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────
# Docker Compose: redis://redis:6379/0  (matches the redis service hostname)
# Railway: copy the full connection URL from your Railway Redis service "Connect" tab
#   e.g. redis://default:<password>@<host>:<port>
REDIS_URL=redis://redis:6379/0

# ── CORS ────────────────────────────────────────────
# Comma-separated list of origins allowed to call this backend
# Set to your Vercel frontend URL in production, e.g. https://mytube.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
# Set to true ONLY during local Docker development (skips origin checks entirely)
CORS_ALLOW_ALL_ORIGINS=false

# ── HTTP port exposed by Nginx ───────────────────────
HTTP_PORT=80

# ── Frontend build ───────────────────────────────────
# Base URL for API calls — keep /api for Docker (nginx proxies)
# Vercel: set to your Railway backend URL, e.g. https://myapp.up.railway.app/api
VITE_API_BASE_URL=/api

# ── Django ───────────────────────────────────────────
# Generate with: openssl rand -base64 50
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-base64-50
# Set to 0 in production, 1 during local development only
DEBUG=0

# Comma-separated list of allowed hostnames
# Docker / local: localhost,127.0.0.1
# Railway: RAILWAY_PUBLIC_DOMAIN is auto-detected — no manual change required.
#          Only add this if you use a custom domain on Railway.
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ────────────────────────────
# OPTION A — Railway (recommended):
#   Railway's PostgreSQL add-on exposes a single DATABASE_URL variable.
#   Copy the "Connection URL" from your Railway PostgreSQL service's "Connect" tab
#   and paste it here.  The backend will automatically use it.
#   DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway
#
# OPTION B — Docker Compose:
#   Leave DATABASE_URL blank and use the individual POSTGRES_* variables below.
#   These match the postgres service credentials in docker-compose.yml.
POSTGRES_DB=mytube
POSTGRES_USER=mytube
POSTGRES_PASSWORD=strong_password_here
# POSTGRES_HOST and POSTGRES_PORT are set by docker-compose (backend service name)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────
# Docker Compose: redis://redis:6379/0  (matches the redis service hostname)
# Railway: copy the full connection URL from your Railway Redis service "Connect" tab
#   e.g. redis://default:<password>@<host>:<port>
REDIS_URL=redis://redis:6379/0

# ── CORS ────────────────────────────────────────────
# Comma-separated list of origins allowed to call this backend.
# Set to your Vercel frontend URL in production, e.g. https://mytube.vercel.app
# VERCEL_URL and FRONTEND_URL env vars are also auto-detected if set.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
# Set to true ONLY during local Docker development (skips origin checks entirely)
CORS_ALLOW_ALL_ORIGINS=false

# Railway: set this to your Vercel app URL so CORS is automatically allowed.
# FRONTEND_URL=https://your-app.vercel.app

# ── HTTP port exposed by Nginx ───────────────────────
HTTP_PORT=80

# ── Frontend build ───────────────────────────────────
# Base URL for API calls — keep /api for Docker (nginx proxies /api → backend)
# Vercel: set to your Railway backend URL, e.g. https://myapp.up.railway.app
VITE_API_BASE_URL=/api
